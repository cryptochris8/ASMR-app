# Copy to .env.local (git-ignored). Never commit a real key.
ELEVENLABS_API_KEY=

# Blockade Labs Skybox AI — used by scripts/generate-skyboxes.js
BLOCKADE_LABS_API_KEY=

# Optional: override ffmpeg/ffprobe binaries used by scripts/audio-pipeline.js
# and scripts/generate-audio.js. Defaults to the binaries on PATH.
# FFMPEG_PATH=
# FFPROBE_PATH=

# Sentry DSN — wired in src/main.ts once @sentry/capacitor is installed.
# VITE_SENTRY_DSN=

# RevenueCat public SDK key — wired in src/game/subscription.ts once
# @revenuecat/purchases-capacitor is installed.
# VITE_REVENUECAT_KEY=
